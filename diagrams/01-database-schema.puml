@startuml Database Schema

!define TABLE(name) entity name

skinparam entity {
  BackgroundColor #FEF3C7
  BorderColor #92400E
  FontColor #1C1917
}
skinparam arrow {
  Color #92400E
}

entity distilleries {
  * id : UUID PK
  --
  * name : VARCHAR(255)
  * region : VARCHAR(50)
  * town : VARCHAR(255)
  founded_year : INTEGER
  latitude : DECIMAL(9,6)
  longitude : DECIMAL(9,6)
  description : TEXT
  production_style : VARCHAR(50)
  is_active : BOOLEAN
  data_source : VARCHAR(50)
  is_published : BOOLEAN
  created_at : TIMESTAMPTZ
  updated_at : TIMESTAMPTZ
}

entity distillery_expressions {
  * id : UUID PK
  --
  * distillery_id : UUID FK
  * name : VARCHAR(255)
}

entity whiskies {
  * id : UUID PK
  --
  * distillery_id : UUID FK
  * name : VARCHAR(255)
  age_years : INTEGER
  abv : DECIMAL(4,1)
  cask_type : VARCHAR(255)
  flavour_profile : TEXT
  tasting_notes : TEXT
  is_limited : BOOLEAN
  data_source : VARCHAR(50)
  is_published : BOOLEAN
  created_at : TIMESTAMPTZ
  updated_at : TIMESTAMPTZ
}

entity users {
  * id : UUID PK
  --
  * email : VARCHAR(255) UNIQUE
  * password_hash : VARCHAR(255)
  display_name : VARCHAR(100)
  role : VARCHAR(20)
  is_active : BOOLEAN
  created_at : TIMESTAMPTZ
}

entity user_distilleries {
  * id : UUID PK
  --
  * user_id : UUID FK
  * distillery_id : UUID FK
  liked : BOOLEAN
  visited : BOOLEAN
  visited_at : DATE
  want_to_visit : BOOLEAN
  notes : TEXT
  created_at : TIMESTAMPTZ
}

entity user_whiskies {
  * id : UUID PK
  --
  * user_id : UUID FK
  * whisky_id : UUID FK
  tasted : BOOLEAN
  tasted_at : DATE
  rating : VARCHAR(20)
  want_to_taste : BOOLEAN
  want_to_buy : BOOLEAN
  owned : BOOLEAN
  tasting_notes : TEXT
  created_at : TIMESTAMPTZ
}

entity whisky_submissions {
  * id : UUID PK
  --
  * submitted_by : UUID FK
  distillery_id : UUID FK
  * name : VARCHAR(255)
  age_years : INTEGER
  abv : DECIMAL(4,1)
  cask_type : VARCHAR(255)
  flavour_profile : TEXT
  status : VARCHAR(20)
  reviewed_by : UUID FK
  reviewed_at : TIMESTAMPTZ
  reviewer_notes : TEXT
  created_at : TIMESTAMPTZ
}

entity ai_enrichment_logs {
  * id : UUID PK
  --
  job_type : VARCHAR(50)
  target_id : UUID
  fields_updated : JSONB
  * triggered_by : UUID FK
  status : VARCHAR(20)
  created_at : TIMESTAMPTZ
}

distilleries ||--o{ distillery_expressions : has
distilleries ||--o{ whiskies : produces
distilleries ||--o{ user_distilleries : tracked_in
whiskies ||--o{ user_whiskies : tracked_in
users ||--o{ user_distilleries : owns
users ||--o{ user_whiskies : owns
users ||--o{ whisky_submissions : submits
whiskies ||--o{ whisky_submissions : referenced_in
users ||--o{ ai_enrichment_logs : triggers

@enduml
